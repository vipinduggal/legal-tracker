# ============================================================
# LEGAL ACCOUNT TRACKER — ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# ============================================================

# ---------------------------
# ANTHROPIC API
# Get your key at: https://console.anthropic.com
# ---------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---------------------------
# EMAIL (Outlook / Office 365)
# Use an app password — NOT your regular password
# Generate at: https://account.microsoft.com/security > App passwords
# ---------------------------
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USER=you@yourcompany.com
EMAIL_PASS=your-app-password-here
EMAIL_FROM=you@yourcompany.com
EMAIL_TO=you@yourcompany.com

# ---------------------------
# SALESFORCE (optional — leave blank to skip)
# Create a Connected App in Salesforce Setup
# ---------------------------
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=

# ---------------------------
# MICROSOFT TEAMS WEBHOOK (optional)
# In Teams: channel > ... > Connectors > Incoming Webhook
# ---------------------------
TEAMS_WEBHOOK_URL=

# ---------------------------
# SCHEDULE (cron syntax)
# Default: daily research at 7 AM, weekly digest Monday 8 AM
# ---------------------------
RESEARCH_CRON=0 7 * * *
DIGEST_CRON=0 8 * * 1

# ---------------------------
# APP SETTINGS
# ---------------------------
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
# Max accounts researched in parallel (keep low to respect API rate limits)
RESEARCH_CONCURRENCY=3
# Days before research is considered stale and re-fetched
RESEARCH_STALE_DAYS=1
