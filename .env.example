# Nazar settings file — copy this to ".env" and fill in your own keys.
# Never share this file once it has your real keys in it.

# Anthropic — get at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Perplexity — get at perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-your-key-here

# CourtListener — get a free token at courtlistener.com (sign in, then profile menu → API)
COURTLISTENER_TOKEN=your-courtlistener-token-here

# SendGrid — get at sendgrid.com (free tier is fine)
SENDGRID_API_KEY=SG.your-sendgrid-key-here

# Your email addresses
EMAIL_FROM=your-verified-sender@gmail.com
EMAIL_TO=your-work-email@consilio.com

# How often to re-research the same account (in days). 3 is a good balance.
RESEARCH_STALE_DAYS=3
