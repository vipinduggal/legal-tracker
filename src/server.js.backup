// server.js — Lightweight Express API + dashboard
// Serves a read-only web dashboard at http://localhost:3000

import express from 'express';
import { ACCOUNTS } from '../config/accounts.js';
import { getAllResearch, getLatestDigest, db } from './db.js';
import { logger } from './logger.js';

const app = express();
app.use(express.json());

// ── API Routes ──────────────────────────────────────────────

// GET /api/accounts — list all accounts with research status
app.get('/api/accounts', async (req, res) => {
  const allResearch = await getAllResearch();
  const data = ACCOUNTS.map(a => ({
    ...a,
    hasData: !!allResearch[a.id],
    lastUpdated: db.data.lastUpdated?.[a.id] || null,
    contactCount: allResearch[a.id]?.contacts?.length || 0,
    activeIssues: [
      ...(allResearch[a.id]?.litigation || []).filter(l => l.status !== 'Resolved' && l.status !== 'Settled'),
      ...(allResearch[a.id]?.regulatory || []).filter(r => r.status !== 'Resolved' && r.status !== 'Closed'),
    ].length,
  }));
  res.json(data);
});

// GET /api/accounts/:id — full research data for one account
app.get('/api/accounts/:id', async (req, res) => {
  const account = ACCOUNTS.find(a => a.id === req.params.id);
  if (!account) return res.status(404).json({ error: 'Account not found' });
  const allResearch = await getAllResearch();
  res.json({
    ...account,
    lastUpdated: db.data.lastUpdated?.[account.id] || null,
    research: allResearch[account.id] || null,
  });
});

// GET /api/digest — latest weekly digest
app.get('/api/digest', async (req, res) => {
  const digest = await getLatestDigest();
  res.json(digest || { message: 'No digest generated yet' });
});

// GET /api/status — health check + run log
app.get('/api/status', async (req, res) => {
  await db.read();
  const allResearch = await getAllResearch();
  const researched = Object.keys(allResearch).length;
  res.json({
    status: 'ok',
    accounts: ACCOUNTS.length,
    researched,
    pending: ACCOUNTS.length - researched,
    recentRuns: (db.data.runs || []).slice(0, 5),
  });
});

// ── Dashboard HTML ──────────────────────────────────────────

app.get('/', async (req, res) => {
  res.send(getDashboardHTML());
});

export function startServer() {
  const port = process.env.PORT || 3000;
  app.listen(port, () => {
    logger.info(`Dashboard running at http://localhost:${port}`);
  });
  return app;
}

function getDashboardHTML() {
  return `<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Legal Account Tracker</title>
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:Segoe UI,Arial,sans-serif;background:#f3f2f1;color:#323130;font-size:14px}
  .topbar{background:#0078d4;color:white;padding:0 24px;height:48px;display:flex;align-items:center;gap:16px}
  .topbar h1{font-size:16px;font-weight:600}
  .topbar .sub{font-size:12px;opacity:.8}
  .main{padding:24px;max-width:1200px;margin:0 auto}
  .stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px}
  .stat-card{background:white;border-radius:4px;padding:14px 16px;border:1px solid #edebe9}
  .stat-num{font-size:28px;font-weight:600;color:#0078d4}
  .stat-label{font-size:12px;color:#605e5c;margin-top:2px}
  .panel{background:white;border-radius:4px;border:1px solid #edebe9;overflow:hidden;margin-bottom:16px}
  .panel-header{padding:12px 16px;border-bottom:1px solid #edebe9;font-weight:600;font-size:14px;display:flex;justify-content:space-between;align-items:center}
  table{width:100%;border-collapse:collapse}
  th{padding:8px 12px;text-align:left;font-size:12px;color:#605e5c;border-bottom:1px solid #edebe9;font-weight:600;text-transform:uppercase;letter-spacing:.03em}
  td{padding:8px 12px;border-bottom:1px solid #f3f2f1;font-size:13px}
  tr:hover td{background:#f3f2f1}
  .badge{display:inline-block;padding:1px 7px;border-radius:10px;font-size:11px;font-weight:500}
  .badge-green{background:#dff6dd;color:#107c10}
  .badge-amber{background:#fff4ce;color:#8a5e06}
  .badge-red{background:#fde7e9;color:#a80000}
  .search{padding:8px 12px;border:1px solid #edebe9;border-radius:2px;font-size:13px;width:260px}
  a{color:#0078d4;text-decoration:none}
  a:hover{text-decoration:underline}
</style>
</head>
<body>
<div class="topbar">
  <h1>⚖️ Legal Account Tracker</h1>
  <span class="sub">Daily intelligence · Automated outreach</span>
</div>
<div class="main">
  <div id="stats" class="stats">
    <div class="stat-card"><div class="stat-num" id="s-total">—</div><div class="stat-label">Total accounts</div></div>
    <div class="stat-card"><div class="stat-num" id="s-researched">—</div><div class="stat-label">Researched</div></div>
    <div class="stat-card"><div class="stat-num" id="s-pending">—</div><div class="stat-label">Pending research</div></div>
    <div class="stat-card"><div class="stat-num" id="s-issues">—</div><div class="stat-label">Active legal issues</div></div>
  </div>

  <div class="panel">
    <div class="panel-header">
      All accounts
      <input class="search" type="text" id="search" placeholder="Search accounts..." oninput="filterTable()" />
    </div>
    <table id="acctTable">
      <thead><tr>
        <th>Account</th><th>Industry</th><th>Location</th>
        <th>Contacts</th><th>Active issues</th><th>Status</th><th>Last updated</th>
      </tr></thead>
      <tbody id="acctBody"></tbody>
    </table>
  </div>
</div>

<script>
let allAccounts = [];

async function load() {
  const [accts, status] = await Promise.all([
    fetch('/api/accounts').then(r => r.json()),
    fetch('/api/status').then(r => r.json()),
  ]);
  allAccounts = accts;
  document.getElementById('s-total').textContent = status.accounts;
  document.getElementById('s-researched').textContent = status.researched;
  document.getElementById('s-pending').textContent = status.pending;
  const totalIssues = accts.reduce((sum, a) => sum + a.activeIssues, 0);
  document.getElementById('s-issues').textContent = totalIssues;
  renderTable(accts);
}

function renderTable(accts) {
  const tbody = document.getElementById('acctBody');
  tbody.innerHTML = accts.map(a => {
    const updated = a.lastUpdated ? new Date(a.lastUpdated).toLocaleDateString() : '—';
    const statusBadge = a.hasData
      ? '<span class="badge badge-green">Researched</span>'
      : '<span class="badge badge-amber">Needs research</span>';
    const issuesBadge = a.activeIssues > 0
      ? \`<span class="badge badge-red">\${a.activeIssues} active</span>\`
      : '<span style="color:#605e5c">None</span>';
    return \`<tr>
      <td><a href="/api/accounts/\${a.id}" target="_blank"><strong>\${a.name}</strong></a></td>
      <td>\${a.industry}</td>
      <td>\${a.location}</td>
      <td>\${a.contactCount || '—'}</td>
      <td>\${issuesBadge}</td>
      <td>\${statusBadge}</td>
      <td>\${updated}</td>
    </tr>\`;
  }).join('');
}

function filterTable() {
  const q = document.getElementById('search').value.toLowerCase();
  renderTable(allAccounts.filter(a =>
    a.name.toLowerCase().includes(q) || a.industry.toLowerCase().includes(q)
  ));
}

load();
</script>
</body>
</html>`;
}
